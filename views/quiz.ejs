<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title><%= cityName %></title>

    <style>
        body {
            font-family: sans-serif;
            text-align: center;
            background-color: white;
        }

        .quiz-container {
            max-width: 600px;
            margin: 40px auto;
            padding: 20px;
            border: 2px solid #ddd;
            border-radius: 10px;
        }

        .flag-placeholder img {
            width: 200px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        .answers button {
            display: block;
            width: 100%;
            margin: 10px 0;
            padding: 10px;
            border: none;
            border-radius: 6px;
            background-color: #0078D4;
            color: white;
            cursor: pointer;
            font-size: 16px;
        }

        .answers button:hover {
            background-color: #005fa3;
        }

        .feedback {
            margin-top: 15px;
            font-weight: bold;
        }

        .next-btn {
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #4caf50;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }
    </style>

    <script> //<!-- TO DO: move this code into a seperate script file -->
        //<!-- Import variables passed from app.js: -->
        //const cityInfo = <%- JSON.stringify(typeof city !== 'undefined' ? city : {}) %>;
        //const citiesTable = <%- JSON.stringify(typeof cities !== 'undefined' ? cities : []) %>;
        //const questionsTable = <%- JSON.stringify(typeof questions !== 'undefined' ? questions : []) %>;
//
        // build a list of 4 answers by taking the answer from the input city and the answers from the next 3 cities from citiesTable. Finally randomize list
        //const answers = [cityInfo[questionsTable[0].field], ...citiesTable.map(item => item[questionsTable[0].field]).slice(0,3)].sort(() => Math.random() - 0.5)
        // Build data for question
        
        const questions = <%- JSON.stringify(typeof questions !== 'undefined' ? questions : {}) %>;
        
        // current question data
        const questionData = {
            question: questions[0].question.question,
            answers: questions[0].choices,
        };
    </script>
</head>

<body>

    <main>
        <div class="quiz-container">
            <h2><%= cityName %></h2>

            <div class="flag-placeholder">
                <img src="/images/<%= cityImg %>" alt="City Image">
            </div>

            <h3 id="question"></h3>

            <div class="answers" id="answers"></div>

            <div class="feedback" id="feedback"></div>

            <button class="next-btn" onclick="nextQuestion()">Next Question</button>
        </div>
    </main>

    <script>

        function loadQuestion() {
            document.getElementById("question").innerText = questionData.question;

            const answersDiv = document.getElementById("answers");
            answersDiv.innerHTML = "";

            questionData.answers.forEach((answer, index) => {
                const btn = document.createElement("button");
                btn.innerText = answer;
                btn.onclick = () => checkAnswer(answer);
                answersDiv.appendChild(btn);
            });
        }

        async function checkAnswer(selected) {


            const response = await fetch('/api/submit-question', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cityID: <%= cityID %>, question: questions[0].question, answer: selected })
            });
            const result = await response.json();
            console.log(result);



            //const feedback = document.getElementById("feedback");
//
            //if (selected === questionData.correct) {
            //    feedback.innerText = "✅ Correct!";
            //    feedback.style.color = "green";
            //} else {
            //    feedback.innerText = "❌ Wrong!";
            //    feedback.style.color = "red";
            //}
        }

        function nextQuestion() {
            location.reload();
            //alert("Next question coming soon (hook this to backend or new data)");
        }

        // Initialize
        loadQuestion();
    </script>

</body>
</html>








